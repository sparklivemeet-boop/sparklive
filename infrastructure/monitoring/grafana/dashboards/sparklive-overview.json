{
  "title": "SparkLive Overview",
  "uid": "sparklive-overview",
  "version": 1,
  "schemaVersion": 36,
  "tags": ["sparklive", "production"],
  "timezone": "utc",
  "editable": true,
  "panels": [
    {
      "title": "Service Health",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 0 },
      "targets": [{
        "expr": "up{job=~\"sparklive-.*\"}",
        "legendFormat": "{{ job }}"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "red" }, { "value": 1, "color": "green" }] }
        }
      }
    },
    {
      "title": "API Request Rate",
      "type": "graph",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 3, "y": 0 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"sparklive-backend\"}[5m]))",
        "legendFormat": "Requests/s"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0
        }
      }
    },
    {
      "title": "API Error Rate",
      "type": "graph",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 11, "y": 0 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"sparklive-backend\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"sparklive-backend\"}[5m])) * 100",
        "legendFormat": "Error %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "thresholds": { "steps": [{ "color": "green" }, { "value": 5, "color": "yellow" }, { "value": 10, "color": "red" }] }
        }
      }
    },
    {
      "title": "API Latency (P95)",
      "type": "graph",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 19, "y": 0 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"sparklive-backend\"}[5m])) by (le))",
        "legendFormat": "P95"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        }
      }
    },
    {
      "title": "Active WebSocket Connections",
      "type": "graph",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [{
        "expr": "sum(websocket_connections_total{job=\"sparklive-websocket\"})",
        "legendFormat": "Connections"
      }]
    },
    {
      "title": "Active Live Streams",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 8, "y": 8 },
      "targets": [{
        "expr": "live_streams_active"
      }]
    },
    {
      "title": "CPU Usage",
      "type": "graph",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 11, "y": 8 },
      "targets": [{
        "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"sparklive\"}[5m])) by (pod)",
        "legendFormat": "{{ pod }}"
      }]
    },
    {
      "title": "Memory Usage",
      "type": "graph",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 19, "y": 8 },
      "targets": [{
        "expr": "sum(container_memory_working_set_bytes{namespace=\"sparklive\"}) by (pod)",
        "legendFormat": "{{ pod }}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Cache Hit Rate",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 16 },
      "targets": [{
        "expr": "sum(rate(cache_hits_total{job=\"sparklive-backend\"}[5m])) / (sum(rate(cache_hits_total{job=\"sparklive-backend\"}[5m])) + sum(rate(cache_misses_total{job=\"sparklive-backend\"}[5m]))) * 100"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "steps": [{ "color": "red" }, { "value": 80, "color": "yellow" }, { "value": 95, "color": "green" }] }
        }
      }
    },
    {
      "title": "Queue Depth",
      "type": "graph",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 4, "y": 16 },
      "targets": [{
        "expr": "queue_depth_total",
        "legendFormat": "Queue Depth"
      }]
    },
    {
      "title": "Database Connections",
      "type": "graph",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 16 },
      "targets": [{
        "expr": "pg_stat_database_numbackends{datname=\"sparklive\"}",
        "legendFormat": "Connections"
      }]
    },
    {
      "title": "Redis Memory Usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 16 },
      "targets": [{
        "expr": "redis_memory_used_bytes / redis_memory_max_bytes * 100"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "steps": [{ "color": "green" }, { "value": 70, "color": "yellow" }, { "value": 85, "color": "red" }] }
        }
      }
    }
  ],
  "rows": [],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "refresh": "30s"
}