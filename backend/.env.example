# ============================================
# SparkLive Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE
# ============================================

# Local Development (SQLite)
DATABASE_URL="file:./dev.db"

# Production (PostgreSQL)
# DATABASE_URL="postgresql://user:password@host:5432/sparklive?schema=public"

# ============================================
# SERVER
# ============================================

PORT=5000
NODE_ENV="development"  # development | production

# ============================================
# CORS & FRONTEND
# ============================================

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Production Frontend URL
# FRONTEND_URL="https://yourdomain.com"

# ============================================
# JWT AUTHENTICATION
# ============================================

# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET="super_secret_sparklive_jwt_key_please_change_in_production_at_least_32_chars"
JWT_EXPIRES_IN="7d"

JWT_REFRESH_SECRET="super_secret_sparklive_refresh_key_please_change_in_production_at_least_32_chars"
JWT_REFRESH_EXPIRES_IN="30d"

# ============================================
# OAUTH - GOOGLE
# ============================================

GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:5000/api/auth/google/callback"

# ============================================
# OAUTH - APPLE
# ============================================

APPLE_CLIENT_ID="com.sparklive.web"
APPLE_TEAM_ID="your-apple-team-id"
APPLE_KEY_ID="your-apple-key-id"
APPLE_KEY_SECRET="your-apple-private-key-content"
APPLE_OAUTH_REDIRECT_URI="http://localhost:5000/api/auth/apple/callback"

# ============================================
# SMS / PHONE OTP
# ============================================

# Twilio
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# Firebase Phone Auth (alternative)
FIREBASE_API_KEY="your-firebase-api-key"
FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
FIREBASE_PROJECT_ID="your-firebase-project-id"

# ============================================
# EMAIL SERVICE
# ============================================

# For password reset emails
EMAIL_SERVICE="sendgrid"  # sendgrid | mailgun | ses
SENDGRID_API_KEY="your-sendgrid-api-key"
EMAIL_FROM_ADDRESS="noreply@sparklive.com"

# ============================================
# RATE LIMITING
# ============================================

RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS="100"  # Max requests per window

# ============================================
# OTP SETTINGS
# ============================================

OTP_LENGTH="6"
OTP_EXPIRY_MINUTES="10"
OTP_MAX_ATTEMPTS="3"

# ============================================
# MONITORING & LOGGING
# ============================================

LOG_LEVEL="debug"  # debug | info | warn | error
SENTRY_DSN="your-sentry-dsn-optional"

# ============================================
# DEPLOYMENT (Railway)
# ============================================

# Railway will automatically set PORT and DATABASE_URL
# but you can override them if needed

