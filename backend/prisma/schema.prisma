generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String?   @unique
  phone           String?   @unique
  phoneNumber     String?   @unique
  passwordHash    String?
  username        String    @unique
  fullName        String?
  bio             String?
  gender          String?
  interestedIn    String?
  age             Int?
  country         String?
  city            String?
  avatar          String?
  verified        Boolean   @default(false)
  emailVerified   Boolean   @default(false)
  coins           Int       @default(0)
  earnings        Float     @default(0.0)
  premium         Boolean   @default(false)
  role            String    @default("USER")
  status          String    @default("ACTIVE")
  googleId        String?   @unique
  appleId         String?   @unique
  lastLoginAt     DateTime?
  loginAttempts   Int       @default(0)
  lockedUntil     DateTime?
  rememberMeToken String?

  // 2FA fields
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  backupCodes      String? // JSON array of hashed backup codes

  // Trusted devices
  trustedDevices TrustedDevice[]

  profile           Profile?
  photos            Photo[]
  notifications     Notification[]           @relation("UserNotifications")
  userEmbeddings    UserEmbedding[]
  userInterests     UserInterest[]
  interactionEvents InteractionEvent[]
  aiContents        AIContent[]
  aiAnalytics       AIAnalytics[]
  fraudAlerts       FraudAlert[]
  aiSessions        AISession[]
  reportsSubmitted  Report[]                 @relation("ReportSubmitter")
  reportsReceived   Report[]                 @relation("ReportTarget")
  followers         Follow[]                 @relation("Following")
  following         Follow[]                 @relation("Follower")
  posts             Post[]                   @relation("UserPosts")
  postLikes         PostLike[]
  postComments      PostComment[]
  videos            Video[]                  @relation("CreatorVideos")
  videoLikes        VideoLike[]
  videoComments     VideoComment[]
  videoSaves        VideoSave[]
  watchHistory      WatchHistory[]
  stories           Story[]
  storyViews        StoryView[]
  ownedCommunities  Community[]              @relation("CommunityOwner")
  communityMembers  CommunityMember[]
  communityPosts    CommunityPost[]
  ownedChannels     Channel[]                @relation("ChannelOwner")
  channelMembers    ChannelMember[]
  channelMessages   ChannelMessage[]
  ownedGroups       Group[]                  @relation("GroupOwner")
  groupMembers      GroupMember[]
  groupMessages     GroupMessage[]
  participants      Participant[]
  messagesSent      Message[]                @relation("MessageSender")
  messageReads      MessageRead[]
  messageReactions  MessageReaction[]
  userPresence      UserPresence?
  liveStreams       LiveStream[]             @relation("HostLiveStreams")
  streamViewers     StreamViewer[]
  liveChatMessages  LiveChatMessage[]
  streamerFollowers StreamFollower[]         @relation("StreamerFollowers")
  userStreamFollows StreamFollower[]         @relation("UserStreamFollows")
  userSettings      UserSettings?
  notificationPrefs NotificationPreferences?
  securityLogs      SecurityLog[]
  sessions          Session[]
  blockedUsers      BlockedUser[]            @relation("BlockedBy")
  blockedBy         BlockedUser[]            @relation("BlockedTarget")
  mutedUsers        MutedUser[]              @relation("MutedBy")
  mutedBy           MutedUser[]              @relation("MutedTarget")

  // Monetization
  purchaseOrders          PurchaseOrder[]
  wallet                  Wallet?
  walletTransactions      WalletTransaction[]
  sentGifts               GiftTransaction[]     @relation("SentGiftTransactions")
  receivedGifts           GiftTransaction[]     @relation("ReceivedGiftTransactions")
  withdrawals             Withdrawal[]
  creatorSubscriptions    CreatorSubscription[] @relation("CreatorSubscriptionRelations")
  subscriberSubscriptions CreatorSubscription[] @relation("SubscriberRelations")
  subscriptionTiers       SubscriptionTier[]
  premiumMembership       PremiumMembership?
  creatorMilestones       CreatorMilestone[]
  giftCombos              GiftCombo[]           @relation("ComboSender")
  receivedGiftCombos      GiftCombo[]           @relation("ComboReceiver")
  leaderboardEntries      LeaderboardEntry[]
  loyaltyLevel            LoyaltyLevel?
  liveGiftEvents          LiveGiftEvent[]       @relation("EventSender")
  receivedLiveGifts       LiveGiftEvent[]       @relation("EventReceiver")

  // Welcome Reward
  welcomeReward    WelcomeReward?
  coinTransactions CoinTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Performance indexes
  @@index([username, status])
  @@index([email, status])
  @@index([role, status])
  @@index([status, createdAt])
  @@index([premium, status])
  @@index([country, status])
  @@index([city, status])
  @@index([gender, interestedIn, status])
  @@index([age, status])
  @@index([lastLoginAt])
  @@index([createdAt])
}

model WelcomeReward {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coins     Int      @default(100)
  claimedAt DateTime @default(now())

  @@index([userId])
}

model CoinTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // WELCOME_REWARD, GIFT_SENT, GIFT_RECEIVED, PURCHASE, SPEND, REFUND, ADMIN
  amount      Int
  balance     Int      @default(0)
  description String?
  reference   String?
  metadata    String? // JSON
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
  @@index([type, createdAt])
}

model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId   String
  deviceName String?
  ipAddress  String?
  userAgent  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@unique([userId, deviceId])
  @@index([deviceId])
  @@index([userId, expiresAt])
}

model Profile {
  id          String         @id @default(cuid())
  username    String         @unique
  fullName    String?
  bio         String?
  avatarUrl   String?
  bannerUrl   String?
  website     String?
  gender      String?
  age         Int?
  country     String?
  city        String?
  interests   String?
  isOnline    Boolean        @default(false)
  socialLinks SocialLink[]
  media       ProfileMedia[]
  userId      String         @unique
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  @@index([country])
  @@index([isOnline])
  @@index([country, isOnline])
  @@index([gender, age])
}

model SocialLink {
  id        String   @id @default(cuid())
  profileId String
  platform  String
  url       String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([profileId, platform])
  @@index([profileId])
}

model ProfileMedia {
  id        String   @id @default(cuid())
  profileId String
  url       String
  type      String   @default("IMAGE")
  title     String?
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([profileId, type])
}

model Photo {
  id        String   @id @default(cuid())
  userId    String
  url       String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId, createdAt])
  @@index([followerId, createdAt])
  @@index([followingId, followerId])
}

model Story {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaUrl  String
  mediaType String      @default("IMAGE")
  caption   String?
  duration  Int         @default(5000)
  viewedBy  StoryView[]
  expiresAt DateTime
  createdAt DateTime    @default(now())

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@index([userId, createdAt, expiresAt])
}

model StoryView {
  id       String   @id @default(cuid())
  storyId  String
  userId   String
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
  viewedAt DateTime @default(now())

  @@unique([storyId, userId])
  @@index([userId, storyId])
  @@index([viewedAt])
}

model Community {
  id          String            @id @default(cuid())
  name        String            @unique
  description String?
  avatar      String?
  bannerUrl   String?
  category    String?
  isPrivate   Boolean           @default(false)
  ownerId     String
  owner       User              @relation("CommunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     CommunityMember[]
  posts       CommunityPost[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([category, isPrivate])
  @@index([createdAt])
  @@index([name])
  @@index([category, createdAt, isPrivate])
}

model CommunityMember {
  id          String    @id @default(cuid())
  communityId String
  userId      String
  role        String    @default("MEMBER")
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
  @@index([communityId, role])
}

model CommunityPost {
  id          String    @id @default(cuid())
  communityId String
  authorId    String
  content     String
  mediaUrl    String?
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([communityId, createdAt])
  @@index([authorId])
  @@index([communityId, authorId, createdAt])
}

model Channel {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  avatar      String?
  category    String?
  ownerId     String
  owner       User             @relation("ChannelOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     ChannelMember[]
  messages    ChannelMessage[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([category])
  @@index([name])
  @@index([ownerId, createdAt])
}

model ChannelMember {
  id        String  @id @default(cuid())
  channelId String
  userId    String
  role      String  @default("MEMBER")
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
  @@index([channelId, role])
}

model ChannelMessage {
  id        String   @id @default(cuid())
  channelId String
  authorId  String
  content   String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([channelId, createdAt])
  @@index([authorId, createdAt])
}

model Group {
  id          String         @id @default(cuid())
  name        String
  description String?
  avatar      String?
  ownerId     String
  owner       User           @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     GroupMember[]
  messages    GroupMessage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([ownerId])
  @@index([name])
  @@index([createdAt])
}

model GroupMember {
  id      String @id @default(cuid())
  groupId String
  userId  String
  role    String @default("MEMBER")
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId, role])
}

model GroupMessage {
  id        String   @id @default(cuid())
  groupId   String
  authorId  String
  content   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([groupId, createdAt])
  @@index([authorId, createdAt])
}

model Video {
  id           String         @id @default(cuid())
  title        String
  description  String?
  videoUrl     String
  thumbnailUrl String?
  duration     Float?
  views        Int            @default(0)
  creatorId    String
  creator      User           @relation("CreatorVideos", fields: [creatorId], references: [id], onDelete: Cascade)
  likes        VideoLike[]
  comments     VideoComment[]
  saves        VideoSave[]
  watchHistory WatchHistory[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([creatorId, createdAt])
  @@index([views, createdAt])
  @@index([createdAt])
  @@index([title])
  @@index([creatorId, views, createdAt])
  @@index([duration, createdAt])
}

model VideoLike {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([videoId, createdAt])
  @@index([userId, createdAt])
}

model VideoComment {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  content   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([videoId, createdAt])
  @@index([userId, createdAt])
}

model VideoSave {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId, userId])
}

model WatchHistory {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  watchTime Float    @default(0.0)
  completed Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([userId, updatedAt])
  @@index([userId, completed, updatedAt])
}

model Post {
  id        String        @id @default(cuid())
  authorId  String
  author    User          @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  mediaUrl  String?
  pinned    Boolean       @default(false)
  likes     PostLike[]
  comments  PostComment[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([authorId, createdAt])
  @@index([createdAt])
  @@index([pinned, authorId])
  @@index([authorId, pinned, createdAt])
  @@index([content])
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId, createdAt])
  @@index([userId, createdAt])
}

model PostComment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  content   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
  @@index([userId, createdAt])
}

model Conversation {
  id           String        @id @default(cuid())
  isGroup      Boolean       @default(false)
  name         String?
  participants Participant[]
  messages     Message[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([updatedAt])
  @@index([id, updatedAt])
}

model Participant {
  id             String       @id @default(cuid())
  userId         String
  conversationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, conversationId])
  @@index([userId, conversationId])
  @@index([conversationId, userId])
}

model Message {
  id             String            @id @default(cuid())
  conversationId String
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User              @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  type           String            @default("TEXT")
  reads          MessageRead[]
  reactions      MessageReaction[]
  attachments    Attachment[]
  createdAt      DateTime          @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@index([conversationId, senderId, createdAt])
  @@index([type, conversationId, createdAt])
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
  @@index([userId, readAt])
  @@index([messageId, userId, readAt])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  reaction  String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([messageId, reaction])
}

model Attachment {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String
  fileType  String
  fileName  String?
  fileSize  Int?
  createdAt DateTime @default(now())

  @@index([messageId])
  @@index([fileType, messageId])
}

model UserPresence {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isOnline   Boolean  @default(false)
  lastActive DateTime @default(now())

  @@index([isOnline, lastActive])
  @@index([lastActive])
}

model LiveStream {
  id           String            @id @default(cuid())
  hostId       String
  host         User              @relation("HostLiveStreams", fields: [hostId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  thumbnailUrl String?
  streamKey    String?
  playbackUrl  String?
  viewerCount  Int               @default(0)
  allowGifts   Boolean           @default(true)
  allowPK      Boolean           @default(false)
  active       Boolean           @default(true)
  categoryName String?
  category     StreamCategory?   @relation(fields: [categoryName], references: [name], onDelete: SetNull)
  viewers      StreamViewer[]
  chatMessages LiveChatMessage[]
  giftEvents   LiveGiftEvent[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([active, viewerCount])
  @@index([hostId, active])
  @@index([categoryName, active])
  @@index([active, createdAt])
  @@index([active, categoryName, viewerCount])
  @@index([hostId, active, createdAt])
  @@index([title])
}

model StreamCategory {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  streams     LiveStream[]

  @@index([name])
}

model LiveChatMessage {
  id        String     @id @default(cuid())
  streamId  String
  stream    LiveStream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  createdAt DateTime   @default(now())

  @@index([streamId, createdAt])
  @@index([userId, streamId, createdAt])
}

model StreamViewer {
  id       String     @id @default(cuid())
  streamId String
  stream   LiveStream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime   @default(now())

  @@unique([streamId, userId])
  @@index([streamId])
  @@index([userId, streamId])
}

model StreamFollower {
  id         String   @id @default(cuid())
  streamerId String
  streamer   User     @relation("StreamerFollowers", fields: [streamerId], references: [id], onDelete: Cascade)
  followerId String
  follower   User     @relation("UserStreamFollows", fields: [followerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([streamerId, followerId])
  @@index([followerId])
  @@index([streamerId, followerId, createdAt])
}

model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme             String   @default("dark")
  privacyProfile    String   @default("public")
  privacyMessages   String   @default("everyone")
  privacyFollows    String   @default("everyone")
  privacyCalls      String   @default("everyone")
  privacyStories    String   @default("everyone")
  privacyLiveStream String   @default("everyone")
  privacyTagging    String   @default("everyone")
  privacyInvites    String   @default("everyone")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model NotificationPreferences {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAlerts Boolean  @default(true)
  pushAlerts  Boolean  @default(true)
  chatAlerts  Boolean  @default(true)
  liveAlerts  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlockedUser {
  id        String   @id @default(cuid())
  userId    String
  targetId  String
  user      User     @relation("BlockedBy", fields: [userId], references: [id], onDelete: Cascade)
  target    User     @relation("BlockedTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, targetId])
  @@index([userId])
  @@index([userId, targetId])
}

model MutedUser {
  id        String   @id @default(cuid())
  userId    String
  targetId  String
  user      User     @relation("MutedBy", fields: [userId], references: [id], onDelete: Cascade)
  target    User     @relation("MutedTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, targetId])
  @@index([userId])
  @@index([userId, targetId])
}

model SecurityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  ipAddress String?
  userAgent String?
  metadata  String? // JSON
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
  @@index([userId, action, createdAt])
  @@index([ipAddress, createdAt])
}

model Session {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token             String    @unique
  refreshToken      String?   @unique
  deviceFingerprint String?
  isTrusted         Boolean   @default(false)
  expiresAt         DateTime
  refreshExpiresAt  DateTime?
  userAgent         String?
  ipAddress         String?
  lastActiveAt      DateTime?
