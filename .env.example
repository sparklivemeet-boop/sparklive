# =============================================================================
# SparkLive - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the actual .env file to version control.
#
# Required variables are marked with (REQUIRED)
# Optional variables have default values shown
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ELECTRON_URL=app://.

# =============================================================================
# DATABASE (REQUIRED)
# =============================================================================
# Local development (SQLite):
# DATABASE_URL=file:./dev.db
# Production (PostgreSQL):
DATABASE_URL=postgresql://user:password@localhost:5432/sparklive

# =============================================================================
# REDIS (for caching, sessions, queues)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# JWT AUTHENTICATION (REQUIRED - generate strong secrets in production)
# =============================================================================
# Generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_REFRESH_SECRET=change-this-to-a-different-strong-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
JWT_ACCESS_EXPIRES_IN=15m
JWT_REMEMBER_ME_EXPIRES_IN=30d

# =============================================================================
# ENCRYPTION (REQUIRED for sensitive data at rest)
# =============================================================================
ENCRYPTION_KEY=change-this-to-a-32-character-hex-string
ENCRYPTION_SALT=sparklive-encryption-salt

# =============================================================================
# SUPERTOKENS (Authentication)
# =============================================================================
SUPERTOKENS_CONNECTION_URI=http://localhost:3567
SUPERTOKENS_API_KEY=
SUPERTOKENS_API_DOMAIN=http://localhost:5000
SUPERTOKENS_WEBSITE_DOMAIN=http://localhost:3000

# =============================================================================
# CLOUDINARY (Media Storage)
# =============================================================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =============================================================================
# STRIPE (Payments)
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# EMAIL (SMTP)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@sparkliveapp.xyz

# =============================================================================
# CDN CONFIGURATION
# =============================================================================
CDN_URL=https://cdn.sparkliveapp.xyz
CDN_API_KEY=

# =============================================================================
# PERFORMANCE MONITORING
# =============================================================================
SLOW_QUERY_THRESHOLD=200
METRICS_INTERVAL=60000

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_API_MAX=60
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_REGISTER_WINDOW_MS=3600000
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_PASSWORD_RESET_WINDOW_MS=3600000
RATE_LIMIT_PASSWORD_RESET_MAX=3
RATE_LIMIT_OTP_WINDOW_MS=900000
RATE_LIMIT_OTP_MAX=5
RATE_LIMIT_MESSAGING_MAX=1
RATE_LIMIT_MESSAGING_WINDOW_MS=1000
RATE_LIMIT_SEARCH_MAX=30
RATE_LIMIT_SEARCH_WINDOW_MS=60000
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_UPLOAD_WINDOW_MS=3600000

# =============================================================================
# FILE UPLOADS
# =============================================================================
MAX_FILE_SIZE=10485760
MAX_IMAGE_SIZE=5242880
MAX_VIDEO_SIZE=104857600
VIRUS_SCAN_ENABLED=false

# =============================================================================
# SECURITY
# =============================================================================
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4
PASSWORD_MIN_LENGTH=12
PASSWORD_MAX_HISTORY=5
PASSWORD_EXPIRY_DAYS=90
MAX_SESSIONS_PER_USER=10
SESSION_CLEANUP_INTERVAL=3600000
BOT_PROTECTION_ENABLED=true
CAPTCHA_ENABLED=false
CAPTCHA_THRESHOLD=0.5
SUSPICIOUS_SCORE_THRESHOLD=0.7
MAX_FAILED_LOGINS=5
LOCKOUT_DURATION=900000
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_ESCALATION_THRESHOLD=10
LOCKOUT_ESCALATION_DURATION=3600000
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365
TOTP_ISSUER=SparkLive
TOTP_BACKUP_CODES=8
TRUSTED_DEVICE_EXPIRY_DAYS=30
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_MAX_AGE=86400
HSTS_MAX_AGE=31536000
GDPR_ENABLED=true
DATA_RETENTION_DAYS=730
DELETION_GRACE_PERIOD_DAYS=30

# =============================================================================
# AI / MODERATION SERVICE
# =============================================================================
AI_SERVICE_URL=http://localhost:5003
AI_AUTO_MODERATE=false

# =============================================================================
# BACKUP
# =============================================================================
BACKUP_DIR=./backups

# =============================================================================
# BACKGROUND JOBS
# =============================================================================
JOB_CONCURRENCY=10
JOB_MAX_RETRIES=3
JOB_BACKOFF_DELAY=1000

# =============================================================================
# CIRCUIT BREAKER
# =============================================================================
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT_MS=30000

# =============================================================================
# IMAGE OPTIMIZATION (via Sharp)
# =============================================================================
IMAGE_QUALITY_HIGH=85
IMAGE_QUALITY_MEDIUM=70
IMAGE_QUALITY_LOW=50

# =============================================================================
# CACHE TTLs (in milliseconds)
# =============================================================================
CACHE_TTL_SHORT=30000
CACHE_TTL_MEDIUM=300000
CACHE_TTL_LONG=3600000
CACHE_TTL_VERY_LONG=86400000

# =============================================================================
# FRONTEND (NEXT_PUBLIC_* variables exposed to browser)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_SENTRY_DSN=

# =============================================================================
# OAUTH PROVIDERS
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
APPLE_CLIENT_ID=com.sparklive.web
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_KEY_SECRET=
APPLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/apple/callback

# =============================================================================
# SMS / PHONE OTP
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_GOOGLE_AUTH=true
ENABLE_APPLE_AUTH=true
ENABLE_PHONE_OTP=true
ENABLE_EMAIL_PASSWORD=true
ENABLE_GIFTS=true
ENABLE_LIVE_STREAMING=true
ENABLE_MESSAGING=true