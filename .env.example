# ============================================
# SparkLive Environment Variables
# ============================================
# This file contains all necessary environment variables for both frontend and backend
# Copy this to .env.local (frontend) and .env (backend) and fill in your values

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Database
# Local SQLite (development): file:./dev.db
# Production PostgreSQL: postgresql://user:password@host:5432/sparklive
DATABASE_URL="file:./dev.db"

# Server
PORT=5000
NODE_ENV="development"  # development | production

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL="https://www.sparkliveapp.xyz"

# Production Frontend URL (for Vercel deployment)
# FRONTEND_URL_PROD="https://www.sparkliveapp.xyz"

# ============================================
# JWT AUTHENTICATION
# ============================================

# Access Token Secret (use a strong random string in production)
JWT_SECRET="replace_with_a_secure_random_secret_at_least_32_characters"

# Access Token Expiry
JWT_EXPIRES_IN="7d"  # 7 days

# Refresh Token Secret (use a different strong random string in production)
JWT_REFRESH_SECRET="replace_with_a_different_secure_random_secret_at_least_32_characters"

# Refresh Token Expiry
JWT_REFRESH_EXPIRES_IN="30d"  # 30 days

# ============================================
# OAUTH PROVIDERS
# ============================================

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:5000/api/auth/google/callback"  # Change for production
# Production: https://your-backend-domain/api/auth/google/callback

# Apple OAuth
APPLE_CLIENT_ID="com.sparklive.web"
APPLE_TEAM_ID="your-apple-team-id"
APPLE_KEY_ID="your-apple-key-id"
APPLE_KEY_SECRET="your-apple-private-key"
APPLE_OAUTH_REDIRECT_URI="http://localhost:5000/api/auth/apple/callback"
# Production: https://your-backend-domain/api/auth/apple/callback

# ============================================
# PHONE OTP / SMS
# ============================================

# Twilio Configuration (Alternative to Firebase)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# Firebase Configuration (Alternative to Twilio)
FIREBASE_API_KEY="your-firebase-api-key"
FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
FIREBASE_PROJECT_ID="your-firebase-project-id"

# ============================================
# EMAIL SERVICE (for password reset emails)
# ============================================

# Sendgrid OR Mailgun OR AWS SES
EMAIL_SERVICE="sendgrid"  # sendgrid | mailgun | aws-ses
SENDGRID_API_KEY="your-sendgrid-api-key"
MAILGUN_API_KEY="your-mailgun-api-key"
MAILGUN_DOMAIN="your-mailgun-domain"
EMAIL_FROM_ADDRESS="noreply@sparklive.com"

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# API Base URL
# For local development
NEXT_PUBLIC_API_URL="http://localhost:5000"

# For production (on Vercel, set this in Vercel dashboard)
# NEXT_PUBLIC_API_URL="https://api.yourdomain.com"
# or if backend is on Railway:
# NEXT_PUBLIC_API_URL="https://your-railway-backend.up.railway.app"

# Google OAuth for Frontend
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Firebase for Phone OTP (Frontend)
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-firebase-project-id"

# Environment
NEXT_PUBLIC_ENV="development"  # development | production

# ============================================
# ANALYTICS & MONITORING
# ============================================

# Vercel Analytics (already configured in layout.tsx)
# Just enable in Vercel dashboard

# Sentry for Error Tracking (optional)
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"

# ============================================
# DEPLOYMENT PLATFORMS
# ============================================

# For Railway Backend Deployment
RAILWAY_ENVIRONMENT="production"

# For Vercel Frontend Deployment
VERCEL_PROJECT_ID="your-vercel-project-id"
VERCEL_ORG_ID="your-vercel-org-id"

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/Disable Features
ENABLE_GOOGLE_AUTH="true"
ENABLE_APPLE_AUTH="true"
ENABLE_PHONE_OTP="true"
ENABLE_EMAIL_PASSWORD="true"
ENABLE_GIFTS="true"
ENABLE_LIVE_STREAMING="true"
ENABLE_MESSAGING="true"

# ============================================
# SECURITY & RATE LIMITING
# ============================================

RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"

# OTP Settings
OTP_LENGTH="6"
OTP_EXPIRY_MINUTES="10"
OTP_MAX_ATTEMPTS="3"

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying to production:
# 1. Replace all JWT_SECRET and JWT_REFRESH_SECRET with strong random values
# 2. Set DATABASE_URL to your production PostgreSQL database
# 3. Configure OAuth providers (Google, Apple)
# 4. Set up SMS provider (Twilio or Firebase)
# 5. Configure email service for password resets
# 6. Update FRONTEND_URL and BACKEND URLs for production domains
# 7. Set NODE_ENV="production"
# 8. Enable HTTPS for all endpoints
# 9. Set up CORS for your production domain
# 10. Configure Rate limiting appropriately

